generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProductCategory {
  CAKES
  CINNABONS
  COMBOS
}

enum Currency {
  EUR
}

enum OrderStatus {
  NEW
  CONFIRMED
  COMPLETED
  CANCELED
}

model Product {
  id          String          @id
  name        String
  category    ProductCategory
  priceMinor  Int
  description String
  image       String
  weight      String?
  filling     String?
  prepTime    String
  orders      Order[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  name            String
  phone           String
  email           String      @default("")
  quantity        Int         @default(1)
  deliveryAddress String      @default("")
  productId       String
  product         Product     @relation(fields: [productId], references: [id])
  productName     String
  unitPriceMinor  Int
  currency        Currency
  totalMinor      Int
  date            DateTime
  comment         String?
  status          OrderStatus @default(NEW)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}
