generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProductCategory {
  CAKES
  CINNABONS
  COMBOS
}

enum Currency {
  EUR
}

enum DeliveryType {
  DELIVERY
  PICKUP
}

enum OrderStatus {
  NEW
  CONFIRMED
  COMPLETED
  CANCELED
}

model Product {
  id          String          @id
  name        String
  category    ProductCategory
  priceMinor  Int
  description String
  image       String
  weight      String?
  filling     String?
  prepTime    String
  orders      Order[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  name            String
  phone           String
  email           String      @default("")
  quantity        Int         @default(1)
  deliveryType    DeliveryType
  deliveryAddress String      @default("")
  productId       String
  product         Product     @relation(fields: [productId], references: [id])
  productName     String
  unitPriceMinor  Int
  currency        Currency
  totalMinor      Int
  date            DateTime
  comment         String?
  status          OrderStatus @default(NEW)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([date])
  @@index([productId])
}

model RateLimit {
  scope     String
  key       String
  count     Int
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@id([scope, key])
  @@index([resetAt])
}

model AdminSession {
  tokenHash String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@index([expiresAt])
  @@index([createdAt])
}

model AdminTotpUse {
  counter BigInt   @id
  usedAt  DateTime @default(now())

  @@index([usedAt])
}

model AdminLoginEvent {
  id             String   @id @default(cuid())
  identifierHash String
  outcome        String
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([identifierHash, createdAt])
}
