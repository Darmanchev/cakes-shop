# Local development. Production must use a remote host and sslmode=verify-full.
DATABASE_URL="postgresql://postgres:postgres@localhost:5435/stas_cakes_shop"
ADMIN_PASSWORD_HASH="scrypt$base64url-salt$base64url-hash"
ADMIN_TOTP_SECRET="BASE32_SECRET_FROM_AUTHENTICATOR_APP"
RATE_LIMIT_SECRET="generate-a-random-secret-with-at-least-32-bytes"
PII_ENCRYPTION_KEY="base64url-encoded-32-byte-key"
# Header that your reverse proxy overwrites with exactly one client IP.
# Keep empty locally. Coolify/Traefik: "x-real-ip"; Cloudflare: "cf-connecting-ip".
TRUSTED_PROXY_IP_HEADER="x-real-ip"
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
TURNSTILE_EXPECTED_HOSTNAME="cakes.example.com"
ORDER_RETENTION_DAYS="365"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
