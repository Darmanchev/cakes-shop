{
  "name": "stas-cakes-shop",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "prestart": "node --import tsx scripts/validate-production-env.ts",
    "start": "next start",
    "env:check": "node --import tsx scripts/validate-production-env.ts",
    "lint": "eslint",
    "test": "node --import tsx --test lib/**/*.test.ts features/**/*.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "pii:encrypt-existing": "node --import tsx scripts/encrypt-existing-order-pii.ts",
    "admin:hash-password": "node scripts/hash-admin-password.mjs",
    "admin:generate-totp-secret": "node scripts/generate-totp-secret.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "libphonenumber-js": "^1.13.9",
    "lucide-react": "^1.26.0",
    "next": "16.2.11",
    "pg": "^8.22.0",
    "prisma": "^7.9.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "server-only": "^0.0.1",
    "tsx": "^4.23.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^22.20.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.11",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.22",
    "sharp": "^0.35.3"
  }
}
